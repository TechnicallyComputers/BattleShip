# BattleShip Android debug.env — ICE automatch / INPUT_BIND soak
# Format: NAME=value  (# comments OK, blank lines OK, optional quotes)
# Only SSB64_*, CURL_CA_BUNDLE, SSL_CERT_FILE are applied (see port/debug_env.c)
# Vars apply only if not already set in the process environment (see per-line loader logs at boot).
# ---------------------------------------------------------------------------
# ICE + matchmaking (current investigation)
# ---------------------------------------------------------------------------
# Log candidate policy, filtered host trickle, etc.
SSB64_MATCHMAKING_ICE_VERBOSE=1
# LAN lab: leave commented (signal local host when you have lan_endpoint).
# LTE / no-LAN: omit local host from signaling SDP/trickle.
# SSB64_MATCHMAKING_ICE_SIGNAL_HOST=0
# Require TURN creds before gather when local LAN is empty (LTE/CGNAT).
# On same Wi‑Fi LAN test, comment this out.
# SSB64_MATCHMAKING_ICE_REQUIRE_TURN=1
# Longer post-match connect budget (ms). Default 60000.
# SSB64_NETPLAY_AUTOMATCH_CONNECT_TIMEOUT_MS=120000
# ---------------------------------------------------------------------------
# NetPeer gates — bind / exec sync / ingress
# ---------------------------------------------------------------------------
# Keep strict input bind (default). Set to 0 to test if VS proceeds without bind.
# SSB64_NETPLAY_REQUIRE_INPUT_BIND=0
# Battle exec sync (default on). Set 0 only for isolation tests.
# SSB64_NETPLAY_BATTLE_EXEC_SYNC=0
# Pump / recv visibility while stuck at bind=0 (rate-limited).
SSB64_NETPLAY_INGRESS_DIAG=1
# Local HID → sim slot mapping (guest Android vs host PC soak).
SSB64_NETPLAY_LOG_LOCAL_INPUT=1
# Log UDP INPUT bundles (noisy).
# SSB64_NETPLAY_UDP_FRAME_TRACE=1
# Extra netpeer state in logs.
# SSB64_NETPLAY_STATE_DETAIL_DIAG=1
# Delay-sync tracing (optional).
SSB64_NETPLAY_DELAY_SYNC_DIAG=1
# ---------------------------------------------------------------------------
# Bootstrap (ICE build skips UDP link-sync probes; harmless if set)
# ---------------------------------------------------------------------------
# SSB64_NETPLAY_UDP_LINK_SYNC=0
# SSB64_NETPLAY_BOOTSTRAP_INGRESS_SYMMETRY=1
# ---------------------------------------------------------------------------
# Dev server override (uncomment if needed)
# ---------------------------------------------------------------------------
# SSB64_MATCHMAKING_BASE_URL=https://netplay.technicallycomputers.ca
# ---------------------------------------------------------------------------
# LTE-only preset (Wi‑Fi off on phone) — uncomment block below
# ---------------------------------------------------------------------------
# SSB64_MATCHMAKING_ICE_VERBOSE=1
# SSB64_MATCHMAKING_ICE_SIGNAL_HOST=0
# SSB64_MATCHMAKING_ICE_REQUIRE_TURN=1
# ---------------------------------------------------------------------------
# Netplay Rollback Diagnostic Flags
# ---------------------------------------------------------------------------
SSB64_NETPLAY_STRICT_SLACK_FRAMES=1
SSB64_NETPLAY_FRAME_COMMIT_DIAG=2
SSB64_NETPLAY_FIGHTER_SLOT_HASH_LOG=1
SSB64_NETPLAY_FIGHTER_SLOT_HASH_TICK_MIN=0
SSB64_NETPLAY_FIGHTER_SLOT_HASH_TICK_MAX=6000
SSB64_NETPLAY_SIM_STATE_TICK_INTERVAL=1
SSB64_NETPLAY_VALIDATION_DUAL_HASH=1
SSB64_NETPLAY_SNAPSHOT_FIGHTER_FIELD_DIFF=1
SSB64_NETPLAY_SNAPSHOT_FIGHTER_DIAG=1
SSB64_NETPLAY_SNAPSHOT_WEAPON_DIAG=1
SSB64_NETPLAY_SNAPSHOT_EFFECT_DIAG=1
SSB64_NETPLAY_SNAPSHOT_ITEM_DIAG=1
SSB64_NETPLAY_SNAPSHOT_RING_SAVE_DIAG=1
SSB64_NETPLAY_RESIM_ANCHOR_PROBE=1
SSB64_NETPLAY_FRAME_COMMIT_DIAG=2
SSB64_NETPLAY_FIGHTER_PHASE_TRACE=1
SSB64_NETPLAY_JOINT_TRANSLATE_TRACE=1
SSB64_NETPLAY_ITEM_HASH_TRACE=1
SSB64_NETPLAY_ITEM_OPCODE_TRACE=1
SSB64_NETPLAY_ITEM_HASH_FIELD_DIFF=1
SSB64_NETPLAY_ITEM_THROW_WINDOW_DIAG=1
SSB64_NETPLAY_RESIM_SIM_CORE_DIAG=1
SSB64_NETPLAY_ROLLBACK_SYNCTEST=1
SSB64_NETPLAY_ROLLBACK_LOAD_HASH_SOFT=1
# SSB64_NETPLAY_ROLLBACK_LOAD_HASH_SOFT=0
SSB64_NETPLAY_ROLLBACK_VERIFY_EFFECT_HASH=1
SSB64_NETPLAY_EFFECT_FOLD_DIAG=1
SSB64_NETPLAY_CROSS_OS_PACING_DIAG=1
# SSB64_NETPLAY_REBIRTH_GATE_DIAG=1
# SSB64_NETPLAY_DEATH_REBIRTH_SIM_DIAG=1
SSB64_NETPLAY_STRICT_STALL_DIAG=1
SSB64_NETPLAY_SNAPSHOT_PARTICLE_DIAG=1
SSB64_NETPLAY_GOBJ_LINK_AUDIT=1
SSB64_NETSYNC_PEER_DIVERGE_DETAIL=1
SSB64_NETPLAY_WORLD_INIT_DIAG=1
SSB64_NETPLAY_STATUSVARS_WITNESS=1
# ------- STAGE SELECT ENV ------------------
SSB64_NETPLAY_AUTOMATCH_STAGE_KIND=6
# Value	Stage
# 0 = Peach's Castle   X
# 1 = Sector Z         X
# 2 = Kongo Jungle     X?
# 3 = Zebes            X
# 4 = Hyrule Castle    X
# 5 = Yoshi's Island   X
# 6 = Dream Land       X
# 7 = Saffron City     X
# 8 = Mushroom Kingdom O
# ------- Map Specific Diag ENV --------------------
# SSB64_NETPLAY_JUNGLE_TARUCANN_DIAG=1
SSB64_NETPLAY_WHISPY_REPAIR_DIAG=1
# ------- Fighter/Level Specific Diag ENV ----------
SSB64_NETPLAY_SNAPSHOT_MAP_HASH_DIAG=1
SSB64_NETPLAY_KIRBY_STONE_RELEASE_DIAG=1
SSB64_NETPLAY_KIRBY_STONE_DAMAGE_DIAG=1
# SSB64_NETPLAY_JUNGLE_TARUCANN_DIAG=1
# SSB64_NETPLAY_FOX_FIREFOX_GATE_DIAG=1
# SSB64_NETPLAY_NESS_PKTHUNDER_GATE_DIAG=1
# SSB64_NETPLAY_SNAPSHOT_ARWING_DIAG=1
# SSB64_NETPLAY_SNAPSHOT_ARWING_NO_ANIM_APPLY=1
# SSB64_NETPLAY_PIKACHU_QUICKATTACK_GATE_DIAG=1
# SSB64_NETPLAY_SNAPSHOT_ARWING_DIAG=1
# SSB64_NETPLAY_HYRULE_TWISTER_DIAG=1
# SSB64_NETPLAY_YAMABUKI_GATE_DIAG=1
# ---------- ICE Debugging Crash ENVs ----------
# SSB64_MATCHMAKING_ICE_HTTPS_SERIALIZE=0
# SSB64_MATCHMAKING_ICE_SUSPEND_POLL=1
# SSB64_MATCHMAKING_ICE_CONCURRENCY=thread
# --------------------------------------
SSB64_DECOMP_DIAG=1
SSB64_NETPLAY_RNG_HASH_TRACE=1
SSB64_NETPLAY_RNG_STEP_TRACE=1
SSB64_NETPLAY_RNG_TRACE_TICK_MIN=0
SSB64_NETPLAY_RNG_TRACE_TICK_MAX=6000
SSB64_NETPLAY_RNG_STEP_SITE=1
SSB64_NETPLAY_RESIM_TICK_TRACE=1

