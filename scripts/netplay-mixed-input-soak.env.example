# Mixed keyboard / analog netplay soak (source before each run: set -a && source this file && set +a)
#
# Host pad vs client keyboard (from GO), or mid-match device switch on either peer.
# Do NOT set SSB64_NETPLAY_PREDICT_NEUTRAL=1 or SSB64_NETPLAY_PREDICTION_RECOVERY=1.

# Symmetric follower + analog-onset defaults (no SYMMETRIC_DIAG)
export SSB64_NETPLAY_RESIM_TICK_TRACE=1
export SSB64_NETPLAY_STATE_DETAIL_DIAG=2
export SSB64_NETPLAY_ROLLBACK_DEFER_DIAG=1
export SSB64_NETPLAY_NETSYNC_LOG_INTERVAL=60
export SSB64_NETPLAY_NEUTRAL_GUARD_TICKS=2
export SSB64_NETPLAY_ANALOG_ONSET_STICK_MAG=12
export SSB64_NETPLAY_ANALOG_ONSET_LOOKBACK=60
export SSB64_NETPLAY_PEER_DIVERGE_DETAIL=1

# Bisect first divergent partition
export SSB64_NETPLAY_SIM_STATE_TICK_INTERVAL=1
export SSB64_NETPLAY_DESYNC_CLASSIFIER=2

# Mixed-input quantize off by default (opt-in only — snaps local sticks to ±85)
# export SSB64_NETPLAY_MIXED_INPUT_QUANTIZE=1
# Resim snapshot refresh on by default; uncomment to bisect
# export SSB64_NETPLAY_RESIM_SNAPSHOT_REFRESH=0

# Optional: log device-switch + quasi-digital prediction (first few lines)
# export SSB64_NETPLAY_MIXED_INPUT_LOG=1

# Epoch pacing + analog decay (defaults; bisect)
# export SSB64_NETPLAY_ROLLBACK_EPOCH_CAP_SLACK=99
# export SSB64_NETPLAY_ANALOG_PRED_DECAY_TICKS=0
# export SSB64_NETPLAY_STICK_MISMATCH_RECOVERY=0

# Pass criteria (both peers, 5+ min):
# - session_negotiated … symmetric=1 symmetric_diag_only=0
# - paired resim begin/complete at same load_tick / target_tick
# - no PEER_SNAPSHOT_DIVERGE / PEER_BASELINE_RESYNC_STORM
# - no prediction recovery armed (stick-mismatch recovery may log; not PREDICTION_RECOVERY)
# - no rollback_epoch_hold with sim far past peer target+slack during peer resim
# - no mirrored RESIM_BASELINE_MISMATCH at same load_tick
# Fail: PEER_DIVERGE_DIFF partition=figh|anim|map with world/rng/item match (convergence)
# Fail: resim complete baseline/post drift without input change (ROLLBACK_IDENTITY_DRIFT)
