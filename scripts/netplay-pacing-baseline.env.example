# Copy or source fragments into your launcher — Phase 1 baseline (both peers must match).
# See docs/netplay_pacing.md → "Phase 1 — Baseline measurement".

export SSB64_NETPLAY_TICK_DIAG=1
export SSB64_NETPLAY_PACING_LOG=1

# Keep identical on both machines for apples-to-apples skew tests:
# export SSB64_NETPLAY_DECOUPLE_DISPLAY_SIM=...
# export SSB64_NETPLAY_SIM_HZ=...

# Optional lead-cap tuning (Phase 2) — restart VS session after changing:
# export SSB64_NETPLAY_SKEW_LEAD_MAX_TICKS=4
