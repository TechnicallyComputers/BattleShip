# KO/respawn lifecycle bisect soak (source before each run: set -a && source this file && set +a)
#
# Targets latent gameplay divergence during stock loss / respawn transitions.
# Do NOT set SSB64_NETPLAY_PREDICT_NEUTRAL=1 — use analog-onset defaults instead.

# Analog-onset + symmetric resim baseline (no SYMMETRIC_DIAG, no PREDICT_NEUTRAL)
export SSB64_NETPLAY_RESIM_TICK_TRACE=1
export SSB64_NETPLAY_STATE_DETAIL_DIAG=2
export SSB64_NETPLAY_ROLLBACK_DEFER_DIAG=1
export SSB64_NETPLAY_NETSYNC_LOG_INTERVAL=30
export SSB64_NETPLAY_NEUTRAL_GUARD_TICKS=2
export SSB64_NETPLAY_ANALOG_ONSET_STICK_MAG=12
export SSB64_NETPLAY_ANALOG_ONSET_LOOKBACK=60

# First-tick bisection
export SSB64_NETPLAY_SIM_STATE_TICK_INTERVAL=1
export SSB64_NETPLAY_DESYNC_CLASSIFIER=2
export SSB64_NETPLAY_PEER_DIVERGE_DETAIL=1

# GObj lifecycle (Phase 3 instrumentation)
export SSB64_NETPLAY_GC_TRAVERSAL_DIAG=2
export SSB64_NETPLAY_GOBJ_EJECT_TRACE=1
export SSB64_NETPLAY_GOBJ_EJECT_RING=32

# Optional: log local hash transitions every sim tick (noisy)
# export SSB64_NETPLAY_HASH_TRANSITION_LOG=1

# Pass criteria (both peers):
# - session_negotiated … symmetric=1 symmetric_diag_only=0
# - no PEER_BASELINE_RESYNC_STORM
# - on failure: PEER_DIVERGE_DIFF names first world partition + DESYNC REPORT peer_snapshot_diverge tick
# - diff host/client sim_state_tick / gc_traversal at same tick for first figh/world/gch split
