# Cross-OS netplay soak (Windows x86_64 <-> Linux x86_64, Android, macOS).
# Copy to debug.env (desktop) or import via Android Port menu -> Restart with debug.env.
# See docs/bugs/netplay_cross_os_pacing_symmetry_2026-05-27.md

# --- Cross-ISA float (keep on both peers) ---
export SSB64_NETPLAY_SIM_F32_QUANTIZE=1

# --- Pacing / commit diagnostics ---
export SSB64_NETPLAY_DELAY_SYNC_DIAG=1
export SSB64_NETPLAY_FRAME_COMMIT_DIAG=2
export SSB64_NETPLAY_VALIDATION_DUAL_HASH=1
export SSB64_NETPLAY_SIM_STATE_TICK_INTERVAL=1
export SSB64_NETPLAY_CROSS_OS_PACING_DIAG=1

# High-Hz Windows hosts: pump UDP during pre-exec display frames
export SSB64_NETPLAY_HOSTFRAME_GATE_PUMP=1

# Startup wire slack (default 2 when unset; explicit for soak)
export SSB64_NETPLAY_STRICT_REMOTE_LEAD_BUFFER_TICKS=2

# Bootstrap ingress symmetry (default on; set 0 only to bisect)
# export SSB64_NETPLAY_BOOTSTRAP_INGRESS_SYMMETRY=0

# Do NOT disable display/sim decouple for cross-OS tests
# export SSB64_NETPLAY_DECOUPLE_DISPLAY_SIM=0

# Fighter / joint oracle (intro window)
export SSB64_NETPLAY_FIGHTER_SLOT_HASH_LOG=1
export SSB64_NETPLAY_FIGHTER_SLOT_HASH_TICK_MIN=0
export SSB64_NETPLAY_FIGHTER_SLOT_HASH_TICK_MAX=150
export SSB64_NETPLAY_SNAPSHOT_FIGHTER_FIELD_DIFF=1

# Optional bisect: quantize off on ONE peer only (confirms ISA float hypothesis)
# export SSB64_NETPLAY_SIM_F32_QUANTIZE=0
