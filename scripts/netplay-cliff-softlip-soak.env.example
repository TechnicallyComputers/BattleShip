# Dream Land CLIFF / JumpAerial / DamageFall soft-lip TopN.x soak (Android arm64 <-> Linux x86_64).
# Copy to debug.env on BOTH peers (desktop user-data + Android files/debug.env).
# See docs/bugs/netplay_damagefall_cliff_softlip_x_diag_2026-07-19.md
#     docs/bugs/netplay_physics_fork_onset_tooling_2026-07-19.md

# Per-tick sim oracle + fighter slots (required for pair sim_state / slot cadence)
export SSB64_NETPLAY_SIM_STATE_TICK_INTERVAL=1
export SSB64_NETPLAY_FIGHTER_SLOT_HASH_LOG=1
# Leave tick window unset (= all ticks) so mid-match forks are visible

# Name AdjNew / SoftLipEx TopN.x writers + sticky latch (REQUIRED — both peers)
# Also emits SoftLipPhase (post_phys/lwall/rwall/ceil/floor) for JumpAerial/CLIFF
# and force-logs lwall_keep / floor_edge_l / lwall_run / …
export SSB64_NETPLAY_SOFTLIP_X_DIAG=1
export SSB64_NETPLAY_LANDING_BRANCH_DIAG=1

# Ness JumpAerial ProcPhysics ja_in→ja_out pipeline (soak 2120480047 ja_in=0 fork)
# Grep JA_VEL_WITNESS; leave off after writer named
export SSB64_JA_VEL_WITNESS=1

# FC seed + field dumps (onset may predate physics fork; prefer MpLanding)
export SSB64_NETPLAY_SNAPSHOT_FIGHTER_FIELD_DIFF=1
export SSB64_NETPLAY_FRAME_COMMIT_DIAG=2
export SSB64_NETPLAY_VALIDATION_DUAL_HASH=1

# Synctest / load-hash soft off for soak pass/fail
export SSB64_NETPLAY_ROLLBACK_SYNCTEST=1
export SSB64_NETPLAY_ROLLBACK_LOAD_HASH_SOFT=0
export SSB64_NETPLAY_ROLLBACK_VERIFY_EFFECT_HASH=1

# Cross-ISA float grid (default on in VS; keep explicit for soaks)
export SSB64_NETPLAY_SIM_F32_QUANTIZE=1

# Analyze:
#   ./scripts/netplay-scan-drift.py --label host android.log --label guest linux.log
#   ./scripts/netplay-trim-logs.py --sync-report --label host android.log --label guest linux.log
# Expect PHYSICS_FORK_ONSET from MpLanding when TopN.x forks before FRAME_COMMIT.
