# Cross-ISA netplay soak (Linux x86_64 <-> Android arm64 / macOS arm64).
# Copy to debug.env (desktop) or import via Android Port menu -> Restart with debug.env.
# See docs/bugs/netplay_cross_isa_determinism_2026-05-27.md

# Core fix (default on during VS when unset; set 0 to bisect ISA vs quantize)
export SSB64_NETPLAY_SIM_F32_QUANTIZE=1

# Per-tick sim oracle
export SSB64_NETPLAY_SIM_STATE_TICK_INTERVAL=1

# Fighter slot hashes (intro window)
export SSB64_NETPLAY_FIGHTER_SLOT_HASH_LOG=1
export SSB64_NETPLAY_FIGHTER_SLOT_HASH_TICK_MIN=0
export SSB64_NETPLAY_FIGHTER_SLOT_HASH_TICK_MAX=150

# Fox P1 joint trace (adjust slot if Fox is P0)
export SSB64_NETPLAY_JOINT_TRANSLATE_TRACE=1
export SSB64_NETPLAY_JOINT_TRANSLATE_TRACE_SLOT=1

export SSB64_NETPLAY_SNAPSHOT_FIGHTER_FIELD_DIFF=1
export SSB64_NETPLAY_SNAPSHOT_RING_SAVE_DIAG=1

export SSB64_NETPLAY_FRAME_COMMIT_DIAG=2
export SSB64_NETPLAY_VALIDATION_DUAL_HASH=1

# Optional: disable quantize only on one peer to confirm ISA hypothesis
# export SSB64_NETPLAY_SIM_F32_QUANTIZE=0
