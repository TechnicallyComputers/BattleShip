# Analog-onset + symmetric resim soak (source before each run: set -a && source this file && set +a)
#
# Replaces symmetric_diag_only soak that only baseline-echoed on the guest.
# Do NOT set SSB64_NETPLAY_ROLLBACK_SYMMETRIC_DIAG=1 for this pass.

# Symmetric follower resim (default when rollback is on; explicit for clarity)
# export SSB64_NETPLAY_ROLLBACK_SYMMETRIC=1

# Rollback diagnostics
export SSB64_NETPLAY_RESIM_TICK_TRACE=1
export SSB64_NETPLAY_STATE_DETAIL_DIAG=2
export SSB64_NETPLAY_ROLLBACK_DEFER_DIAG=1

# NetSync checkpoints every 60 sim ticks (default 120) — catches late drift past tick 3600
export SSB64_NETPLAY_NETSYNC_LOG_INTERVAL=60

# Optional analog-onset trace (first few onset predictions)
# export SSB64_NETPLAY_ANALOG_ONSET_LOG=1

# Analog onset defaults (override only to bisect)
# export SSB64_NETPLAY_NEUTRAL_GUARD_TICKS=2
# export SSB64_NETPLAY_ANALOG_ONSET_STICK_MAG=12
# export SSB64_NETPLAY_ANALOG_ONSET_LOOKBACK=60

# Pass criteria (both peers):
# - session_negotiated … symmetric=1 symmetric_diag_only=0
# - GGPO deferred input correction resim + resim begin/complete on initiator and follower
# - no RESIM_BASELINE_ECHO spam after resim complete for stale load_tick
# - no PEER_BASELINE_RESYNC_STORM (cap=8 steps / ring depth)
# - fewer pred=1 sx=0 sy=0 lines on idle→walk / jump onset vs pre-analog-onset build
