# Mid-match fighter determinism bisect (source before each run: set -a && source this file && set +a)
#
# Targets @420/@600/@900-class failures: matching commit inputs, divergent figh, baseline universe mismatch.
# Pair with automatch host/client; compare fighter_slot_hash (fhash_full + anim_hash) on both logs.

# Episode FSM is default-on; uncomment to bisect legacy resim input path:
# export SSB64_NETPLAY_ROLLBACK_EPISODE_FSM=0
export SSB64_NETPLAY_NETSYNC_LOG_INTERVAL=1
export SSB64_NETPLAY_SIM_STATE_TICK_INTERVAL=1
export SSB64_NETPLAY_SNAPSHOT_FIGHTER_DIAG=1
export SSB64_NETPLAY_SNAPSHOT_FIGHTER_FIELD_DIFF=1
export SSB64_NETPLAY_RESIM_TICK_TRACE=1
export SSB64_NETPLAY_STATE_DETAIL_DIAG=2
export SSB64_NETPLAY_FIGHTER_PHASE_TRACE=1
export SSB64_NETPLAY_FIGHTER_SLOT_HASH_LOG=1
export SSB64_NETPLAY_FIGHTER_SLOT_HASH_TICK_MIN=400
export SSB64_NETPLAY_FIGHTER_SLOT_HASH_TICK_MAX=920
# First per-slot fhash_light step: fighter_detail at prev_tick + tick (no per-tick detail flood)
export SSB64_NETPLAY_FHASH_LIGHT_MISMATCH_TRIGGER=1
export SSB64_NETPLAY_FHASH_LIGHT_MISMATCH_TICK_MIN=400
export SSB64_NETPLAY_FHASH_LIGHT_MISMATCH_TICK_MAX=920
export SSB64_NETPLAY_FHASH_LIGHT_MISMATCH_TRIGGER_SECOND_MIN=473
# Optional: one-step probe after load (ring vs live at load_tick+1)
# export SSB64_NETPLAY_RESIM_ANCHOR_PROBE=1
export SSB64_NETPLAY_GOBJ_EJECT_TRACE=1
export SSB64_NETPLAY_FRAME_COMMIT_DIAG=2
export SSB64_NETPLAY_HASH_TRANSITION_LOG=1
export SSB64_NETPLAY_PEER_DIVERGE_DETAIL=1

# Optional: local-only synctest round-trip during match (adds load-verify noise)
# export SSB64_NETPLAY_ROLLBACK_SYNCTEST=1

# Pass criteria (both peers):
# - First fighter_slot_hash fhash_full mismatch tick documented between peers
# - FC@900+ clean OR recovery: baseline_matched=1 / RESIM_POST_MATCH, no BASELINE_UNIVERSE_STORM_CAP / Abort(snapshot_fidelity)
# Fail: FRAME_COMMIT_STATE_DIVERGE with matching inp_*, divergent figh, baseline_matched=0
# See docs/bugs/fighter_snapshot_fidelity_2026-05-21.md
