# UDP link sync: default ON; on timeout bootstrap continues (fallback). Skip entirely:
# export SSB64_NETPLAY_UDP_LINK_SYNC=0
# Lab strict (abort bootstrap if link proof fails):
# export SSB64_NETPLAY_UDP_LINK_SYNC_REQUIRED=1

# Bootstrap / staging defaults are tuned for high RTT (no env required). Override examples:
# export SSB64_NETPLAY_BOOTSTRAP_RETRY_COUNT=480
# export SSB64_NETPLAY_STAGE_SCENE_GO_HOLD_MS=3000
# export SSB64_NETPLAY_BOOTSTRAP_PAUSE_BETWEEN_MS=800

# Auto session negotiation (default ON when unset).
# Host measures RTT via TIME_PING during VS sync, then proposes D from fixed tiers
# (2/2/3/5/7/8 frames by RTT), phase_lock (one-way runway, not D+D/2), redundancy, ingress pumps, strict_ring_fuzz,
# rollback snapshot depth, resim budget, and symmetric rollback flags.
# Adaptive delay is OFF unless you set SSB64_NETPLAY_ADAPTIVE_DELAY=1 (testing only).
# Override only for lab bisect:
# export SSB64_NETPLAY_AUTO_SESSION_PARAMS=0

# Rollback is negotiated per match (~200 ms RTT example: D<=8, phase_lock=8, snap~32-40, resim=6-8, fuzz=1-2).
# Local kill-switch still wins:
# export SSB64_NETPLAY_ROLLBACK=0
#
# Automatch defaults to **no items**; enable spawn + rollback item soak with:
# export SSB64_NETPLAY_AUTOMATCH_ITEMS=1

# Manual delay still wins when set (transport knobs still negotiated when auto is on):
# export SSB64_NETPLAY_DELAY=14
# export SSB64_NETPLAY_MATCH_INPUT_DELAY=14

# Disable auto entirely and use legacy manual profile:
# export SSB64_NETPLAY_AUTO_SESSION_PARAMS=0
# export SSB64_NETPLAY_DELAY=14
# export SSB64_NETPLAY_PHASE_LOCK_PREDICTION_TICKS=8
# export SSB64_NETPLAY_INPUT_BUNDLE_REDUNDANCY=2
# export SSB64_NETPLAY_INGRESS_EXTRA_PUMPS_ON_STALL=3
