# Developer / soak diagnostics only — NOT player settings.
# Copy to your BattleShip user-data folder as debug.env (same dir as ssb64.log).
#
# Android: Internal storage → Documents → BattleShip/debug.env
#   adb push scripts/debug.env.example /sdcard/Documents/BattleShip/debug.env
# Desktop: ~/Library/Application Support/BattleShip/debug.env (macOS), etc.
#
# Values apply only when unset in the process environment (shell export wins on PC).
# Restart the app after editing. Remove or rename the file to return to defaults.

SSB64_NETPLAY_DELAY_SYNC_DIAG=1
# SSB64_NETPLAY_FRAME_COMMIT_DIAG=2
# SSB64_MATCHMAKING_BASE_URL=https://your-dev-server.example
